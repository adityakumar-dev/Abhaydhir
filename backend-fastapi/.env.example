# Supabase Configuration
SUPABASE_URL=your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Configuration (used for legacy support if needed)
LEGACY_JWT_SECRET=your-jwt-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-for-file-tokens

# Security Keys for User Registration
REGISTER_SECURITY_KEY=your-security-registration-key
REGISTER_ADMIN_KEY=your-admin-registration-key

# Public Link Security
PUBLIC_LINK_SECRET=your-public-link-secret-key

# SMS Provider Configuration
# Choose provider: twilio, msg91
SMS_PROVIDER=twilio

# Default country code for phone numbers (if not provided in number)
# Examples: +91 (India), +1 (US/Canada), +44 (UK)
DEFAULT_COUNTRY_CODE=+91

# Twilio Configuration (if using Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# MSG91 Configuration (if using MSG91 - Indian SMS Provider)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=your-sender-id
MSG91_ROUTE=4

# AWS SNS Configuration (if using AWS SNS)
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# Application Configuration
BASE_URL=http://localhost:8000

# Email Configuration (DEPRECATED - Now using SMS)
# EMAIL_ADDRESS=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
